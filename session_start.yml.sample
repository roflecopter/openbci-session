default:
    port: '/dev/cu.usbserial-DP04WFVJ'
    session_dir: '/path/to/sesion_db'

    session_file: 'sessions.db'
    sql_dt_format: '%Y-%m-%d %H:%M:%S'

activity: 1

# Optional firmware tunables (T-protocol + %TUNE in SESSION.TXT). Each value
# below is the firmware default; override only the keys you want changed and
# the rest stay at default. CLI flag `--tune key=value` (repeatable) overlays
# this block per-run. Out-of-range values are rejected before the board is
# touched. Omit the whole block entirely to use firmware defaults.
# tune:
#   max_resumes:      25      # 1..254  resume cap (EEPROM[7])
#   ext_recovery_ms:  8000    # 1..60000  extended in-place recovery window
#   ext_chunk_ms:     500     # 10..5000  per-retry chunk (≤ ext_recovery_ms)
#   ckpt_interval_ms: 60000   # 1000..3600000  %CKPT heartbeat interval
#   sd_write_timeout: 1500    # 100..5000  per-block SD write timeout

electrodes:
  1: Gold Cup OpenBCI, Ten20
  2: Premium Ag/AgCl FRI, Sigma Gel
  3: Premium Ag/AgCl FRI
  4: Ag/AgCl FRI disposable, Sigma Gel
  5: Gold Cup Grass, Ten20
  6: Gold Cup OpenBCI, Sigma Gel
  7: Ambu Neuroline Cup, Sigma Gel

montages:
  sleep_channels:
    F8-AFz: 0
    F7-AFz: 1
    O2-AFz: 2
    O1-AFz: 3    

  emg_channels:
    ECG-AI: 4

  emg_empty:
      
activities:
  1:
    type: sleep
    dur: 12H
    sf: 250
    ground: Fp2
    gain: 24
    electrode: 1
    ch: sleep_channels
    dev: cyton
    emg: emg_channels
    note:     
  2:
    type: meditation
    dur: 1H
    sf: 250
    ground: AFz
    gain: 24
    electrode: 4
    ch: sleep_channels
    dev: daisy
    emg: emg_empty
    note: 
